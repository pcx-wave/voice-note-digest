# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-your-botfather-token-here
# Comma-separated Telegram user IDs allowed to use the bot. Empty = allow everyone.
ALLOWED_USER_IDS=
# Fixed sender->name map: "id:Name,id:Name". Overrides voice biometrics for that sender.
SENDER_NAMES=

# --- Speech-to-text (transcription) ---
# provider: openai | azure | mistral
STT_PROVIDER=openai
STT_API_KEY=
STT_MODEL=whisper-1
# Only for STT_PROVIDER=azure:
AZURE_STT_ENDPOINT=

# --- LLM (summary) ---
# OpenAI-compatible chat endpoint. Mistral works out of the box.
LLM_PROVIDER=mistral
LLM_API_KEY=
LLM_MODEL=mistral-large-latest
LLM_BASE_URL=https://api.mistral.ai/v1

# --- Storage ---
DATA_DIR=./data
MEDIA_DIR=./data/inbound
DB_PATH=./data/memory.db
RETENTION_DAYS=90

# --- Optional speaker ID ---
# Directory with one subfolder per speaker, each containing sample.wav
VOICE_SAMPLES_DIR=./data/voice_samples
